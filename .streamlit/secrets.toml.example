# Rename this file to secrets.toml for local use,
# OR paste these as secrets in the Streamlit Cloud dashboard (Settings → Secrets).

GROQ_API_KEY     = "your_groq_api_key_here"

# Qdrant Cloud — get from cloud.qdrant.io → your cluster → API Keys
QDRANT_URL       = "https://xxxx-xxxx.us-east4-0.gcp.cloud.qdrant.io:6333"
QDRANT_API_KEY   = "your_qdrant_api_key_here"

EMBEDDING_MODEL_NAME = "BAAI/bge-base-en-v1.5"
RERANKER_MODEL_NAME  = "cross-encoder/ms-marco-MiniLM-L-6-v2"
LLM_MODEL            = "llama-3.3-70b-versatile"
LLM_TEMPERATURE      = "0.3"
LLM_MAX_TOKENS       = "4096"

# Optional: protect the app with a password
# APP_PASSWORD = "your_password_here"
